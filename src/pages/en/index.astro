---
import BaseLayout from '../../layouts/BaseLayout.astro';
import profilePhoto from '../../img/Angel-Lillo-caricatura.jpeg';
import { profileEn, contactsEn, highlightsEn, projectsEn, techEn, focusEn } from '../../data/portfolio-en';
---

<BaseLayout title="Ángel Lillo | Backend Engineer" description={profileEn.summary}>
  <header class="topbar">
    <div class="topbar-inner shell">
      <a href="#home" class="brand brand-mark">
        <span class="brand-badge">AL</span>
        <span>
          <strong>Ángel Lillo</strong>
          <small>Backend Engineer</small>
        </span>
      </a>
      <button
        id="menu-toggle"
        class="menu-toggle"
        type="button"
        aria-label="Open navigation"
        aria-controls="site-nav"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav id="site-nav" class="site-nav">
        <a href="#home">Home</a>
        <a href="#profile">Profile</a>
        <a href="#experience">Experience</a>
        <a href="#stack">Stack</a>
        <a href="#contact">Contact</a>
        <a href="/" class="lang-switch" aria-label="Cambiar a Español">ES</a>
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color mode">🌙</button>
      </nav>
    </div>
  </header>

  <main class="page-shell">
    <section id="home" class="hero-panel frame-panel">
      <aside class="hero-rail" aria-label="Visual hero navigation">
        <span class="hero-index">01</span>
        <span class="hero-line"></span>
        <span class="hero-dots">
          <i></i><i></i><i></i>
        </span>
      </aside>

      <div class="hero-copy">
        <p class="eyebrow">Hello, I'm</p>
        <h1 class="hero-title">
          <span>{profileEn.name.split(' ')[0]}</span>
          <span class="accent">{profileEn.name.split(' ').slice(1).join(' ')}</span>
        </h1>
        <p class="hero-role">{profileEn.role}</p>
        <p class="hero-summary">{profileEn.summary}</p>

        <div class="hero-metrics" aria-label="Primary areas">
          <span>Critical systems</span>
          <span>Serverless architecture</span>
          <span>Cloud &amp; Data</span>
        </div>

        <div class="actions hero-actions">
          <a href="#experience" class="btn primary">View experience</a>
          <a href="/CV-Angel-Lillo-HUMAN-EN.pdf" class="btn" download>Professional CV</a>
          <a href="/CV-Angel-Lillo-ATS-EN.pdf" class="btn" download>ATS CV</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-visual-frame">
          <div class="hero-code-card" aria-hidden="true">
            <span>const profile = {'{'}</span>
            <span>role: 'Backend Engineer',</span>
            <span>focus: 'Serverless · Cloud · Data',</span>
            <span>approach: 'Technical ownership',</span>
            <span>{'}'};</span>
          </div>
          <img src={profilePhoto.src} alt="Ángel Lillo profile picture" class="hero-photo" width="420" height="520" loading="eager" />
        </div>
      </div>
    </section>

    <section id="profile" class="section-block split-block">
      <article class="side-card frame-panel">
        <span class="section-number">02</span>
        <div>
          <span class="section-kicker">Profile</span>
          <h2>About me</h2>
        </div>
      </article>

      <article class="content-card frame-panel">
        <span class="section-kicker">Professional summary</span>
        <h2>Technical ownership focused on clarity, resilience, and real-world operations</h2>
        <p>{profileEn.summary}</p>

        <div class="responsibility-grid">
          <div class="responsibility-card">
            <strong>Responsible for</strong>
            <p>Technical design, implementation, and production operations across backend and AWS environments.</p>
          </div>
          <div class="responsibility-card">
            <strong>Specialization</strong>
            <p>Serverless architecture, enterprise integration, data platforms, and continuous improvement.</p>
          </div>
        </div>

        <div class="content-subsection">
          <span class="section-kicker">Technologies</span>
          <div class="tech-groups">
            <div>
              <h3>Core</h3>
              <div class="chips">
                {techEn.core.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
            <div>
              <h3>Complementary</h3>
              <div class="chips">
                {techEn.complementary.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="section-block split-block highlights-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">03</span>
        <div>
          <span class="section-kicker">Strengths</span>
          <h2>Areas with demonstrated production impact</h2>
        </div>
      </article>
      <article class="content-card frame-panel">
        <ul class="highlight-grid">
          {highlightsEn.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section id="experience" class="section-block">
      <div class="section-headline">
        <span class="section-number inline">04</span>
        <div>
          <span class="section-kicker">Experience</span>
          <h2>Responsibilities and work context</h2>
        </div>
      </div>

      <div class="project-grid">
        {projectsEn.map((project) => (
          <article class="project-card frame-panel">
            <div class="project-header">
              <div>
                <h3>{project.name}</h3>
                <p class="project-context">{project.context}</p>
              </div>
            </div>

            <div class="project-section">
              <h4>Responsible for</h4>
              <ul>
                {project.responsibilities.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            {project.results.length > 0 && (
              <div class="project-section">
                <h4>Participation and impact</h4>
                <ul>
                  {project.results.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            )}

            <div class="project-section">
              <h4>Relevant stack</h4>
              <div class="chips">
                {project.stack.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>

            {project.links && project.links.length > 0 && (
              <div class="actions project-actions">
                {project.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn">{link.label || 'View project'}</a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="stack" class="section-block split-block focus-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">05</span>
        <div>
          <span class="section-kicker">Focus</span>
          <h2>Areas where I currently add the most value</h2>
        </div>
      </article>
      <article class="content-card frame-panel">
        <ul class="focus-list">
          {focusEn.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section id="contact" class="section-block split-block contact-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">06</span>
        <div>
          <span class="section-kicker">Contact</span>
          <h2>Direct channels</h2>
        </div>
      </article>

      <article class="content-card frame-panel contact-layout">
        <div>
          <span class="section-kicker">Let's talk</span>
          <h2>Available channels to connect or coordinate</h2>
          <div class="contact-list">
            <a href={contactsEn.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href={contactsEn.github} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={contactsEn.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <a href={`mailto:${contactsEn.emails[0]}`}>{contactsEn.emails[0]}</a>
            <a href={`mailto:${contactsEn.emails[1]}`}>{contactsEn.emails[1]}</a>
          </div>
        </div>

        <div class="contact-code-card">
          <span>const developer = {'{'}</span>
          <span>name: '{profileEn.name}',</span>
          <span>focus: '{profileEn.role}',</span>
          <span>approach: 'Responsible for design, implementation, and operations'</span>
          <span>{'}'};</span>
        </div>
      </article>
    </section>
  </main>

  <script>
    const key = 'angel-theme';
    const root = document.documentElement;
    const toggleBtn = document.getElementById('theme-toggle');
    const menuToggle = document.getElementById('menu-toggle');
    const siteNav = document.getElementById('site-nav');
    const mobileQuery = window.matchMedia('(max-width: 820px)');

    const savedTheme = localStorage.getItem(key);
    if (savedTheme === 'light') root.dataset.theme = 'light';

    const refreshThemeIcon = () => {
      if (!toggleBtn) return;
      const isLight = root.dataset.theme === 'light';
      toggleBtn.textContent = isLight ? '🌞' : '🌙';
    };

    refreshThemeIcon();

    toggleBtn?.addEventListener('click', () => {
      const next = root.dataset.theme === 'light' ? 'dark' : 'light';
      if (next === 'light') root.dataset.theme = 'light';
      else delete root.dataset.theme;
      localStorage.setItem(key, next);
      refreshThemeIcon();
    });

    const syncMobileNav = () => {
      if (!menuToggle || !siteNav) return;

      const isMobile = mobileQuery.matches;
      if (!isMobile) {
        siteNav.removeAttribute('hidden');
        menuToggle.setAttribute('aria-expanded', 'false');
        return;
      }

      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      siteNav.toggleAttribute('hidden', !isOpen);
    };

    menuToggle?.addEventListener('click', () => {
      if (!siteNav) return;
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
      siteNav.toggleAttribute('hidden', isOpen);
    });

    siteNav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (!mobileQuery.matches || !menuToggle || !siteNav) return;
        menuToggle.setAttribute('aria-expanded', 'false');
        siteNav.setAttribute('hidden', '');
      });
    });

    mobileQuery.addEventListener('change', syncMobileNav);
    syncMobileNav();
  </script>
</BaseLayout>
