---
import BaseLayout from '../layouts/BaseLayout.astro';
import profilePhoto from '../img/Angel-Lillo-caricatura.jpeg';
import { profile, contacts, highlights, projects, tech, focus } from '../data/portfolio';
---

<BaseLayout title="Ángel Lillo | Backend Engineer" description={profile.summary}>
  <header class="topbar">
    <div class="topbar-inner shell">
      <a href="#inicio" class="brand brand-mark">
        <span class="brand-badge">AL</span>
        <span>
          <strong>Ángel Lillo</strong>
          <small>Backend Engineer</small>
        </span>
      </a>
      <nav>
        <a href="#inicio">Inicio</a>
        <a href="#perfil">Perfil</a>
        <a href="#experiencia">Experiencia</a>
        <a href="#stack">Stack</a>
        <a href="#contacto">Contacto</a>
        <a href="/en/" class="lang-switch" aria-label="Switch to English">EN</a>
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Cambiar tema">🌙</button>
      </nav>
    </div>
  </header>

  <main class="page-shell">
    <section id="inicio" class="hero-panel frame-panel">
      <aside class="hero-rail" aria-label="Navegación visual de portada">
        <span class="hero-index">01</span>
        <span class="hero-line"></span>
        <span class="hero-dots">
          <i></i><i></i><i></i>
        </span>
      </aside>

      <div class="hero-copy">
        <p class="eyebrow">Hola, soy</p>
        <h1 class="hero-title">
          <span>{profile.name.split(' ')[0]}</span>
          <span class="accent">{profile.name.split(' ').slice(1).join(' ')}</span>
        </h1>
        <p class="hero-role">{profile.role}</p>
        <p class="hero-summary">{profile.summary}</p>

        <div class="hero-metrics" aria-label="Áreas principales">
          <span>Sistemas críticos</span>
          <span>Arquitectura serverless</span>
          <span>Cloud &amp; Data</span>
        </div>

        <div class="actions hero-actions">
          <a href="#experiencia" class="btn primary">Ver experiencia</a>
          <a href="/CV-Angel-Lillo-HUMAN-ES.pdf" class="btn" download>CV Profesional</a>
          <a href="/CV-Angel-Lillo-ATS-ES.pdf" class="btn" download>CV ATS</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-visual-frame">
          <div class="hero-code-card" aria-hidden="true">
            <span>const profile = {'{'}</span>
            <span>role: 'Backend Engineer',</span>
            <span>focus: 'Serverless · Cloud · Data',</span>
            <span>approach: 'Responsabilidad técnica',</span>
            <span>{'}'};</span>
          </div>
          <img src={profilePhoto.src} alt="Foto de perfil de Ángel Lillo" class="hero-photo" width="420" height="520" loading="eager" />
        </div>
      </div>
    </section>

    <section id="perfil" class="section-block split-block">
      <article class="side-card frame-panel">
        <span class="section-number">02</span>
        <div>
          <span class="section-kicker">Perfil</span>
          <h2>Sobre mí</h2>
        </div>
      </article>

      <article class="content-card frame-panel">
        <span class="section-kicker">Resumen profesional</span>
        <h2>Responsabilidad técnica con foco en claridad, resiliencia y operación real</h2>
        <p>{profile.summary}</p>

        <div class="responsibility-grid">
          <div class="responsibility-card">
            <strong>Responsable de</strong>
            <p>Diseño técnico, implementación y operación productiva en backend y AWS.</p>
          </div>
          <div class="responsibility-card">
            <strong>Especialización</strong>
            <p>Arquitecturas serverless, integración empresarial, datos y mejora continua.</p>
          </div>
        </div>

        <div class="content-subsection">
          <span class="section-kicker">Tecnologías</span>
          <div class="tech-groups">
            <div>
              <h3>Core</h3>
              <div class="chips">
                {tech.core.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
            <div>
              <h3>Complementario</h3>
              <div class="chips">
                {tech.complementary.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="section-block split-block highlights-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">03</span>
        <div>
          <span class="section-kicker">Fortalezas</span>
          <h2>Áreas donde ya existe impacto comprobado</h2>
        </div>
      </article>
      <article class="content-card frame-panel">
        <ul class="highlight-grid">
          {highlights.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section id="experiencia" class="section-block">
      <div class="section-headline">
        <span class="section-number inline">04</span>
        <div>
          <span class="section-kicker">Experiencia</span>
          <h2>Responsabilidades y contexto de trabajo</h2>
        </div>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card frame-panel">
            <div class="project-header">
              <div>
                <h3>{project.name}</h3>
                <p class="project-context">{project.context}</p>
              </div>
            </div>

            <div class="project-section">
              <h4>Responsable de</h4>
              <ul>
                {project.responsibilities.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            {project.results.length > 0 && (
              <div class="project-section">
                <h4>Participación e impacto</h4>
                <ul>
                  {project.results.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            )}

            <div class="project-section">
              <h4>Stack involucrado</h4>
              <div class="chips">
                {project.stack.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>

            {project.links && project.links.length > 0 && (
              <div class="actions project-actions">
                {project.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn">{link.label || 'Ver proyecto'}</a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="stack" class="section-block split-block focus-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">05</span>
        <div>
          <span class="section-kicker">Enfoque</span>
          <h2>Frentes donde hoy aporto más valor</h2>
        </div>
      </article>
      <article class="content-card frame-panel">
        <ul class="focus-list">
          {focus.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section id="contacto" class="section-block split-block contact-block">
      <article class="side-card frame-panel compact-side">
        <span class="section-number">06</span>
        <div>
          <span class="section-kicker">Contacto</span>
          <h2>Canales directos</h2>
        </div>
      </article>

      <article class="content-card frame-panel contact-layout">
        <div>
          <span class="section-kicker">Hablemos</span>
          <h2>Canales disponibles para conversar o coordinar</h2>
          <div class="contact-list">
            <a href={contacts.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href={contacts.github} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={`mailto:${contacts.emails[0]}`}>{contacts.emails[0]}</a>
            <a href={`mailto:${contacts.emails[1]}`}>{contacts.emails[1]}</a>
          </div>
        </div>

        <div class="contact-code-card">
          <span>const developer = {'{'}</span>
          <span>name: '{profile.name}',</span>
          <span>focus: '{profile.role}',</span>
          <span>approach: 'Responsable de diseño, implementación y operación'</span>
          <span>{'}'};</span>
        </div>
      </article>
    </section>
  </main>

  <script>
    const key = 'angel-theme';
    const root = document.documentElement;
    const toggleBtn = document.getElementById('theme-toggle');

    const savedTheme = localStorage.getItem(key);
    if (savedTheme === 'light') root.dataset.theme = 'light';

    const refreshThemeIcon = () => {
      if (!toggleBtn) return;
      const isLight = root.dataset.theme === 'light';
      toggleBtn.textContent = isLight ? '🌞' : '🌙';
    };

    refreshThemeIcon();

    toggleBtn?.addEventListener('click', () => {
      const next = root.dataset.theme === 'light' ? 'dark' : 'light';
      if (next === 'light') root.dataset.theme = 'light';
      else delete root.dataset.theme;
      localStorage.setItem(key, next);
      refreshThemeIcon();
    });
  </script>
</BaseLayout>
