---
import '../styles/global.css';

type Locale = 'es' | 'en';

interface AlternateLocale {
  lang: Locale | 'x-default';
  path: string;
}

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  canonicalPath?: string;
  alternateLocales?: AlternateLocale[];
}

const {
  title = 'Portafolio | Ángel Lillo',
  description = 'Portafolio profesional de Ángel Lillo, Backend Engineer especializado en AWS serverless y datos.',
  lang = 'es',
  canonicalPath = Astro.url.pathname,
  alternateLocales = []
} = Astro.props;

const site = Astro.site;
const canonicalUrl = site ? new URL(canonicalPath, site).toString() : undefined;
const ogImage = site ? new URL('/favicon.jpeg', site).toString() : '/favicon.jpeg';
const locale = lang === 'es' ? 'es_CL' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0b1020" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {alternateLocales.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.lang}
        href={site ? new URL(alternate.path, site).toString() : alternate.path}
      />
    ))}
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />
    <link rel="apple-touch-icon" href="/favicon.jpeg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
    <slot />
  </body>
</html>
